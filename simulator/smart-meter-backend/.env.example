# Server Configuration
PORT=8080

# Device Configuration
DEVICE_ID=smart-meter-001

# MQTT Configuration
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_TLS_PORT=8883
MQTT_USE_TLS=true
MQTT_TLS_SKIP_VERIFY=false
MQTT_TLS_SERVER_NAME=mosquitto
MQTT_TLS_CA_CERT=/certs/ca.crt
MQTT_USERNAME=smart-meter-001
MQTT_PASSWORD=smart-meter-001_password
