{
    admin 0.0.0.0:2019
}

:80 {
    # Nested handles: ledger/consumption paths before device catch-all under /devices*.
    handle /devices* {
        handle /devices/*/balance* {
            uri path_regexp ^(.*)$ /api/v1$1
            reverse_proxy ledger:8080
        }
        handle /devices/*/entries* {
            uri path_regexp ^(.*)$ /api/v1$1
            reverse_proxy ledger:8080
        }
        handle /devices/*/credit* {
            uri path_regexp ^(.*)$ /api/v1$1
            reverse_proxy ledger:8080
        }
        handle /devices/*/debit* {
            uri path_regexp ^(.*)$ /api/v1$1
            reverse_proxy ledger:8080
        }
        handle /devices/*/authorizations* {
            uri path_regexp ^(.*)$ /api/v1$1
            reverse_proxy ledger:8080
        }
        handle /devices/*/invoices* {
            uri path_regexp ^(.*)$ /api/v1$1
            reverse_proxy ledger:8080
        }
        handle /devices/*/consumptions* {
            uri path_regexp ^(.*)$ /api/v1$1
            reverse_proxy consumption:8080
        }
        handle /devices/*/accumulations* {
            uri path_regexp ^(.*)$ /api/v1$1
            reverse_proxy consumption:8080
        }
        handle {
            uri path_regexp ^(.*)$ /api/v1$1
            reverse_proxy device:8080
        }
    }

    handle /lnd/info* {
        uri path_regexp ^(.*)$ /api/v1$1
        reverse_proxy lightning:8080
    }

    handle /lnd/wallet* {
        uri path_regexp ^(.*)$ /api/v1$1
        reverse_proxy lightning:8080
    }

    handle /health {
        respond 200
    }

    handle {
        respond 404
    }
}
