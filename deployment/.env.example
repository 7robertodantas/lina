# Redis Configuration
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MQTT Configuration
MQTT_PORT=1883
MQTT_TLS_PORT=8883
MQTT_USE_TLS=true
MQTT_TLS_SKIP_VERIFY=false
MQTT_TLS_SERVER_NAME=mosquitto
MQTT_TLS_CA_CERT=/certs/ca.crt
MQTT_TLS_REQUIRE_EDGE_CERT=false
MQTT_TLS_EDGE_CERT=/certs/edge.crt
MQTT_TLS_EDGE_KEY=/certs/edge.key
MQTT_DYNSEC_ADMIN_USER=dynsec_admin_user
MQTT_DYNSEC_ADMIN_PASSWORD=

# Device Service
DEVICE_SERVICE_MQTT_USERNAME=device_service_user
DEVICE_SERVICE_MQTT_PASSWORD=

# Service Tokens
SERVICE_TOKEN=dev-token

# Service Listen Addresses
LISTEN_ADDR=:8080
GRPC_ADDR=:9090
GRPC_PORT=9090

# Lightning Service Configuration
LND_HOST=127.0.0.1:10001 # host.docker.internal:10001
LND_TLS_CERT_HEX=
LND_MACAROON_HEX=
LIGHTNING_RPC_TIMEOUT_SECONDS=30

# OpenTelemetry Configuration
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp # none
OTEL_EXPORTER_OTLP_PROTOCOL=grpc # none
OTEL_EXPORTER_OTLP_ENDPOINT=jaeger:4317 # empty

# Gin Mode
GIN_MODE=release

# Auto Pay
RECEIVER_LND_HOST=127.0.0.1:10001 # host.docker.internal:10001
RECEIVER_LND_TLS_CERT_HEX=
RECEIVER_LND_TLS_SERVER_NAME=localhost
RECEIVER_LND_MACAROON_HEX=

PAYER_LND_HOST=127.0.0.1:10002 # host.docker.internal:10002
PAYER_LND_TLS_CERT_HEX=
PAYER_LND_TLS_SERVER_NAME=localhost
PAYER_LND_MACAROON_HEX=
