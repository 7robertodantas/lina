# Copy to `hosts` if you want a separate file:
#   cp inventory/hosts.example inventory/hosts

[edge]
edge-pi ansible_host=192.168.1.50 ansible_user=pi

# Default: Go cross-compile on the machine running ansible-playbook into
# deployment/ansible/.build/linux-arm64 (override with lina_build_goarch, etc. in group_vars).
#
# To use pre-built binaries on the controller instead:
# [edge:vars]
# lina_build_binaries=false
# lina_binaries_dir=/absolute/path/to/device,ledger,consumption,lightning
