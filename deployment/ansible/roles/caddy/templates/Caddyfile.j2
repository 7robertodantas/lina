# Managed by Ansible — same routing as infrastructure/caddy/Caddyfile
{
    admin {{ lina_caddy_admin }}
}

{{ lina_caddy_listen }} {
    # Nested handles: first match under /devices* wins (ledger/consumption before device catch-all).
    handle /devices* {
        handle /devices/*/balance* {
            uri path_regexp ^(.*)$ /api/v1$1
            reverse_proxy {{ lina_caddy_upstream_ledger }}
        }
        handle /devices/*/entries* {
            uri path_regexp ^(.*)$ /api/v1$1
            reverse_proxy {{ lina_caddy_upstream_ledger }}
        }
        handle /devices/*/credit* {
            uri path_regexp ^(.*)$ /api/v1$1
            reverse_proxy {{ lina_caddy_upstream_ledger }}
        }
        handle /devices/*/debit* {
            uri path_regexp ^(.*)$ /api/v1$1
            reverse_proxy {{ lina_caddy_upstream_ledger }}
        }
        handle /devices/*/authorizations* {
            uri path_regexp ^(.*)$ /api/v1$1
            reverse_proxy {{ lina_caddy_upstream_ledger }}
        }
        handle /devices/*/invoices* {
            uri path_regexp ^(.*)$ /api/v1$1
            reverse_proxy {{ lina_caddy_upstream_ledger }}
        }
        handle /devices/*/consumptions* {
            uri path_regexp ^(.*)$ /api/v1$1
            reverse_proxy {{ lina_caddy_upstream_consumption }}
        }
        handle /devices/*/accumulations* {
            uri path_regexp ^(.*)$ /api/v1$1
            reverse_proxy {{ lina_caddy_upstream_consumption }}
        }
        handle {
            uri path_regexp ^(.*)$ /api/v1$1
            reverse_proxy {{ lina_caddy_upstream_device }}
        }
    }

    handle /lnd/info* {
        uri path_regexp ^(.*)$ /api/v1$1
        reverse_proxy {{ lina_caddy_upstream_lightning }}
    }

    handle /lnd/wallet* {
        uri path_regexp ^(.*)$ /api/v1$1
        reverse_proxy {{ lina_caddy_upstream_lightning }}
    }

    handle /health {
        respond 200
    }

    handle {
        respond 404
    }
}
