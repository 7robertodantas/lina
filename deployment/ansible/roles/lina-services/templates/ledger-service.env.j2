REPOSITORY_TYPE={{ lina_repository_type }}
DB_PATH={{ lina_ledger_db_path }}
SERVICE_TOKEN={{ lina_service_token }}
LISTEN_ADDR={{ lina_ledger_listen_addr }}
GRPC_ADDR={{ lina_ledger_grpc_addr }}
{% if lina_grpc_tls_enabled | default(true) | bool %}
GRPC_USE_TLS=true
GRPC_TLS_CA_CERT={{ lina_mosquitto_cafile }}
GRPC_TLS_SERVER_CERT={{ lina_mosquitto_certfile }}
GRPC_TLS_SERVER_KEY={{ lina_mosquitto_keyfile }}
{% else %}
GRPC_USE_TLS=false
{% endif %}
METRICS_ADDR={{ lina_ledger_metrics_addr }}
REDIS_HOST={{ lina_redis_host }}
REDIS_PORT={{ lina_redis_port }}
REDIS_DB=0
{% if (lina_redis_password | default('') | string | length) > 0 %}
REDIS_PASSWORD={{ lina_redis_password }}
{% endif %}
STREAM_READ_COUNT={{ lina_ledger_stream_read_count }}
STREAM_PARALLELISM={{ lina_ledger_stream_parallelism }}
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=ledger-service
OTEL_TRACES_EXPORTER=none
OTEL_METRICS_EXPORTER=none
GIN_MODE=release
