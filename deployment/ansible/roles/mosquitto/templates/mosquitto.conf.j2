# Managed by Ansible — aligned with infrastructure/mosquitto/config/mosquitto.conf
per_listener_settings false

{% if lina_mosquitto_dynsec_enable | default(true) | bool %}
allow_anonymous false
{% else %}
allow_anonymous true
{% endif %}

{% if lina_mosquitto_tls_enable | default(false) | bool %}
listener {{ lina_mosquitto_tls_port | int }}
protocol mqtt
cafile {{ lina_mosquitto_cafile }}
certfile {{ lina_mosquitto_certfile }}
keyfile {{ lina_mosquitto_keyfile }}
require_certificate false
{% endif %}

listener {{ lina_mosquitto_plain_port | int }}
protocol mqtt

{% if lina_mosquitto_websocket_plain_enable | default(false) | bool %}
listener {{ lina_mosquitto_websocket_plain_port | int }}
protocol websockets
{% endif %}

{% if (lina_mosquitto_tls_enable | default(false) | bool) and (lina_mosquitto_websocket_tls_enable | default(false) | bool) %}
listener {{ lina_mosquitto_websocket_tls_port | int }}
protocol websockets
cafile {{ lina_mosquitto_cafile }}
certfile {{ lina_mosquitto_certfile }}
keyfile {{ lina_mosquitto_keyfile }}
{% endif %}

# log_dest: inherit distro default (usually file/syslog); stdout can break some systemd setups
log_type error
log_type warning
log_type notice

# Broker state (main mosquitto.conf persistence* lines are commented by the Ansible role)
persistence true
persistence_location /var/lib/mosquitto/

max_connections -1
max_inflight_messages 20
max_queued_messages 1000

{% if lina_mosquitto_dynsec_enable | default(true) | bool %}
plugin {{ lina_mosquitto_dynsec_plugin_path }}
plugin_opt_config_file {{ lina_mosquitto_dynsec_config_file }}
{% endif %}
