#!/bin/sh
# Mirrors infrastructure/mosquitto/config/entrypoint.sh (dynsec) +
# infrastructure/mosquitto/generate-dynsec.sh init-only.
# Credentials are passed via MQTT_DYNSEC_ADMIN_USER / MQTT_DYNSEC_ADMIN_PASSWORD (not stored in this file).

DYNSEC_FILE="{{ lina_mosquitto_dynsec_config_file }}"
DYNSEC_DIR="{{ lina_mosquitto_dynsec_config_file | dirname }}"

MQTT_DYNSEC_ADMIN_USER="${MQTT_DYNSEC_ADMIN_USER:?MQTT_DYNSEC_ADMIN_USER is required}"
MQTT_DYNSEC_ADMIN_PASSWORD="${MQTT_DYNSEC_ADMIN_PASSWORD:?MQTT_DYNSEC_ADMIN_PASSWORD is required}"

mkdir -p "$DYNSEC_DIR"
chmod 0755 "$DYNSEC_DIR"

if [ ! -f "$DYNSEC_FILE" ]; then
    echo "dynamic-security.json not found. Initializing it..."
    mosquitto_ctrl dynsec init "$DYNSEC_FILE" "$MQTT_DYNSEC_ADMIN_USER" "$MQTT_DYNSEC_ADMIN_PASSWORD"
    if [ $? -ne 0 ]; then
        echo "Failed to initialize dynamic-security.json"
        exit 1
    fi
    echo "dynamic-security.json initialized successfully"
else
    echo "dynamic-security.json already exists, skipping initialization"
fi

if id mosquitto >/dev/null 2>&1; then
    chown mosquitto:mosquitto "$DYNSEC_DIR" 2>/dev/null || true
fi
chmod 0755 "$DYNSEC_DIR"

exit 0
